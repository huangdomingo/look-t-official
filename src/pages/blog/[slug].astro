---
import Layout from '../../layouts/Layout.astro';
import { fetchPostBySlug, fetchPosts } from '../../lib/wordpress';

export async function getStaticPaths() {
  const posts = await fetchPosts(100);
  return posts.map((post: any) => ({ params: { slug: post.slug } }));
}

const { slug } = Astro.params;
const post = await fetchPostBySlug(slug);
if (!post) return Astro.redirect('/blog');

const thumb = post._embedded?.['wp:featuredmedia']?.[0]?.source_url;
---

<Layout title={`${post.title.rendered} — Look-T`} description={post.excerpt?.rendered?.replace(/<[^>]+>/g, '')}>
  <article class="post-detail">
    {thumb && <img class="hero" src={thumb} alt={post.title.rendered} />}
    <div class="content">
      <h1 set:html={post.title.rendered} />
      <time>{new Date(post.date).toLocaleDateString('zh-TW')}</time>
      <div class="body" set:html={post.content.rendered} />
      <a href="/blog" class="back">← 回部落格列表</a>
    </div>
  </article>
</Layout>

<style>
  .post-detail { max-width: 800px; margin: 0 auto; padding: 4rem 1.5rem; }
  .hero {
    width: 100%;
    max-height: 400px;
    object-fit: cover;
    border-radius: 8px;
    margin-bottom: 2rem;
  }
  h1 { font-size: 1.8rem; color: #d4af6a; margin-bottom: 0.4rem; }
  time { font-size: 0.85rem; color: #888; }
  .body {
    margin-top: 2rem;
    line-height: 1.9;
    color: #ccc;
  }
  .body :global(h2) { color: #d4af6a; margin-top: 2rem; }
  .body :global(img) { border-radius: 6px; margin: 1rem 0; }
  .back {
    display: inline-block;
    margin-top: 3rem;
    color: #d4af6a;
    text-decoration: none;
  }
  .back:hover { text-decoration: underline; }
</style>