---
import Layout from '../layouts/Layout.astro';
---

<Layout title="聯絡我們 | Look-T 真空管工作室" description="預約試聽、維修諮詢、產品洽詢">
  <main>
    <header class="page-hero">
      <div class="container">
        <h1>聯絡我們</h1>
        <p>預約試聽／維修諮詢／產品洽詢</p>
      </div>
    </header>

    <section class="section">
      <div class="container">
        <div class="contact-grid">

          <div class="contact-info">
            <h2>洽詢方式</h2>
            <div class="info-item">
              <span class="icon">📍</span>
              <div>
                <h3>工作室位置</h3>
                <p>桃園市中壢區中央西路二段141巷22號</p>
              </div>
            </div>
            <div class="info-item">
              <span class="icon">📞</span>
              <div>
                <h3>電話</h3>
                <p>03-493-4239</p>
              </div>
            </div>
            <div class="info-item">
              <span class="icon">📧</span>
              <div>
                <h3>電子郵件</h3>
                <p>請透過下方表單與我們聯繫</p>
              </div>
            </div>
            <div class="info-item">
              <span class="icon">🕐</span>
              <div>
                <h3>服務時間</h3>
                <p>週日至週六　14:00 – 20:00</p>
              </div>
            </div>
            <div class="info-item">
              <span class="icon">📝</span>
              <div>
                <h3>維修預約</h3>
                <p>請提前來信說明器材型號與症狀，我們會盡快回覆。</p>
              </div>
            </div>
          </div>

          <div class="contact-form">
            <h2>傳送訊息</h2>
            <form id="contactForm">
              <div class="form-group">
                <label for="name">姓名 *</label>
                <input type="text" id="name" placeholder="您的姓名" required />
              </div>
              <div class="form-group">
                <label for="email">電子郵件 *</label>
                <input type="email" id="email" placeholder="your@email.com" required />
              </div>
              <div class="form-group">
                <label for="subject">詢問主題</label>
                <select id="subject">
                  <option value="">請選擇</option>
                  <option value="audition">預約試聽</option>
                  <option value="repair">維修諮詢</option>
                  <option value="product">產品洽詢</option>
                  <option value="other">其他</option>
                </select>
              </div>
              <div class="form-group">
                <label for="message">訊息內容 *</label>
                <textarea id="message" rows="5" placeholder="請描述您的需求..." required></textarea>
              </div>
              <button type="submit" class="submit-btn">送出訊息</button>
            </form>
          </div>

        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  :root { --bg: #0f0f0f; --surface: #1a1a1a; --primary: #d4af37; --text: #e0e0e0; --text-muted: #a0a0a0; }
  .container { max-width: 1000px; margin: 0 auto; padding: 0 20px; }
  .page-hero { padding: 60px 0; text-align: center; border-bottom: 2px solid var(--primary); }
  h1 { font-size: 2.5rem; margin: 0; color: var(--primary); }
  .page-hero p { color: var(--text-muted); margin: 10px 0 0; }
  .section { padding: 60px 0; }
  .contact-grid { display: grid; grid-template-columns: 1fr 1.2fr; gap: 60px; }
  h2 { font-size: 1.4rem; color: var(--primary); border-left: 4px solid var(--primary); padding-left: 15px; margin: 0 0 30px; }
  .info-item { display: flex; gap: 16px; margin-bottom: 28px; }
  .icon { font-size: 1.5rem; flex-shrink: 0; margin-top: 2px; }
  h3 { color: var(--text); font-size: 1rem; margin: 0 0 6px; }
  p { color: var(--text-muted); font-size: 0.95rem; line-height: 1.7; margin: 0; }
  .form-group { margin-bottom: 20px; }
  label { display: block; color: var(--text-muted); font-size: 0.9rem; margin-bottom: 8px; }
  input, select, textarea {
    width: 100%; padding: 12px 16px; background: var(--surface);
    border: 1px solid #333; border-radius: 6px; color: var(--text);
    font-size: 0.95rem; font-family: inherit; box-sizing: border-box;
    transition: border-color 0.2s;
  }
  input:focus, select:focus, textarea:focus { outline: none; border-color: var(--primary); }
  select option { background: var(--surface); }
  textarea { resize: vertical; }
  .submit-btn { width: 100%; padding: 14px; background: var(--primary); color: #000; font-weight: bold; font-size: 1rem; border: none; border-radius: 6px; cursor: pointer; transition: opacity 0.2s; }
  .submit-btn:hover { opacity: 0.85; }
  @media (max-width: 768px) { .contact-grid { grid-template-columns: 1fr; gap: 40px; } }
</style>