---
import Layout from '../layouts/Layout.astro';
import { fetchFAQs } from '../lib/wordpress';

const faqs = await fetchFAQs();

const categoryLabels: Record<string, string> = {
  audition: '試聽／選購',
  purchase: '購買／訂購',
  care: '保養／維護',
  troubleshoot: '故障排除',
};

const grouped = faqs.reduce((acc: any, faq: any) => {
  const cat = faq.acf?.faq_category || 'other';
  if (!acc[cat]) acc[cat] = [];
  acc[cat].push(faq);
  return acc;
}, {});
---

<Layout title="常見問答 | Look-T 真空管工作室">
  <main>
    <header class="page-hero">
      <div class="container">
        <h1>常見問答</h1>
        <p>FAQ</p>
      </div>
    </header>

    <section class="section">
      <div class="container">
        {Object.entries(grouped).map(([cat, items]: any) => (
          <div class="faq-group">
            <h2>{categoryLabels[cat] || cat}</h2>
            {items.map((faq: any) => (
              <details class="faq-item">
                <summary>{faq.title?.rendered}</summary>
                <div class="answer" set:html={faq.content?.rendered} />
              </details>
            ))}
          </div>
        ))}
      </div>
    </section>
  </main>
</Layout>

<style>
  :root { --bg: #0f0f0f; --surface: #1a1a1a; --primary: #d4af37; --text: #e0e0e0; --text-muted: #a0a0a0; }
  body { background: var(--bg); color: var(--text); font-family: "PingFang TC", "Microsoft JhengHei", sans-serif; margin: 0; }
  .container { max-width: 800px; margin: 0 auto; padding: 0 20px; }
  .page-hero { padding: 60px 0; text-align: center; border-bottom: 2px solid var(--primary); }
  h1 { font-size: 2.5rem; margin: 0; color: var(--primary); }
  .page-hero p { color: var(--text-muted); margin: 10px 0 0; }
  .section { padding: 60px 0; }
  .faq-group { margin-bottom: 50px; }
  h2 { border-left: 4px solid var(--primary); padding-left: 15px; margin: 0 0 25px; font-size: 1.3rem; color: var(--primary); }
  .faq-item { background: var(--surface); border: 1px solid #333; border-radius: 8px; margin-bottom: 12px; overflow: hidden; }
  summary { padding: 18px 25px; cursor: pointer; font-size: 1rem; font-weight: bold; list-style: none; display: flex; justify-content: space-between; align-items: center; }
  summary::-webkit-details-marker { display: none; }
  summary::after { content: '+'; color: var(--primary); font-size: 1.4rem; font-weight: normal; }
  details[open] summary::after { content: '−'; }
  .answer { padding: 0 25px 20px; color: var(--text-muted); line-height: 1.8; border-top: 1px solid #333; padding-top: 15px; }
</style>