---
import Layout from '../layouts/Layout.astro';

// 準備從 WordPress 抓取資料 (預留 API 邏輯)
const siteName = "Look-T 音響";
const tagline = "追求極致音質的工藝美學";
---

<Layout title={siteName}>
	<main>
		<section class="hero">
			<h1>{siteName}</h1>
			<p class="tagline">{tagline}</p>
			<div class="status-badge">官方網站建設中</div>
		</section>

		<section class="api-status">
			<h2>系統連線狀態</h2>
			<ul>
				<li><span class="status-ok">●</span> 基礎設施：Cloudflare Pages 已就緒</li>
				<li><span class="status-ok">●</span> 內容管理：WordPress REST API 已連通</li>
				<li><span class="status-working">●</span> 視覺開發：Astro 組件建置中</li>
			</ul>
		</section>
	</main>
</Layout>

<style>
	main {
		margin: auto;
		padding: 2rem;
		width: 800px;
		max-width: calc(100% - 2rem);
		color: #1a1a1a;
		font-family: "PingFang TC", "Microsoft JhengHei", sans-serif;
		line-height: 1.6;
	}
	.hero {
		text-align: center;
		padding: 4rem 0;
		background: linear-gradient(135deg, #1e1e1e 0%, #333333 100%);
		color: white;
		border-radius: 12px;
		margin-bottom: 2rem;
	}
	h1 {
		font-size: 3.5rem;
		font-weight: 700;
		margin: 0;
		letter-spacing: 2px;
	}
	.tagline {
		font-size: 1.2rem;
		opacity: 0.8;
		margin-top: 0.5rem;
	}
	.status-badge {
		display: inline-block;
		margin-top: 1.5rem;
		padding: 0.5rem 1.5rem;
		background: #d4af37; /* 金色系，象徵高級音響 */
		color: #000;
		font-weight: bold;
		border-radius: 50px;
		font-size: 0.9rem;
	}
	.api-status {
		background: #f4f4f4;
		padding: 2rem;
		border-radius: 12px;
		border: 1px solid #ddd;
	}
	h2 {
		margin-top: 0;
		font-size: 1.5rem;
		border-bottom: 2px solid #1e1e1e;
		display: inline-block;
		padding-bottom: 0.5rem;
	}
	ul {
		list-style: none;
		padding: 0;
	}
	li {
		margin: 1rem 0;
		display: flex;
		align-items: center;
	}
	.status-ok {
		color: #28a745;
		margin-right: 0.7rem;
	}
	.status-working {
		color: #ffc107;
		margin-right: 0.7rem;
		animation: pulse 1.5s infinite;
	}
	@keyframes pulse {
		0% { opacity: 1; }
		50% { opacity: 0.4; }
		100% { opacity: 1; }
	}
</style>
