---
import Layout from '../layouts/Layout.astro';
import { fetchProducts, fetchRepairLogs, fetchPosts } from '../lib/wordpress';
import { fetchProducts, fetchRepairLogs } from '../lib/wordpress';

const products = await fetchProducts(6);
const posts = await fetchPosts(3);
const repairLogs = await fetchRepairLogs(4);
---

<Layout title="Look-T 真空管工作室">
 <main>
  <header class="hero">
   <div class="container">
    <h1>Look-T 真空管工作室</h1>
    <p class="tagline">追求極致音質的工藝美學</p>
   </div>
  </header>

  <section class="section">
   <div class="container">
    <div class="section-header">
     <h2>職人維修實錄</h2>
     <a href="/repair-logs" class="more-link">查看更多案例 →</a>
    </div>
    <div class="grid">
     {repairLogs.map((log: any) => (
      <article class="card">
       {log._embedded?.['wp:featuredmedia']?.[0]?.source_url && (
        <div class="card-image" style={`background-image: url(${log._embedded['wp:featuredmedia'][0].source_url})`}></div>
       )}
       <div class="card-content">
        <span class="date">{log.date?.slice(0, 10)}</span>
        <h3>{log.title?.rendered}</h3>
        {log.acf?.symptom && <p><strong>症狀：</strong>{log.acf.symptom}</p>}
        <div class="status-tag">完修</div>
       </div>
      </article>
     ))}
    </div>
   </div>
  </section>

<section class="section">
    <div class="container">
      <div class="section-header">
        <h2>最新文章</h2>
        <a href="/blog" class="more-link">查看全部文章 →</a>
      </div>
      <div class="grid">
        {posts.map((post: any) => {
          const thumb = post._embedded?.['wp:featuredmedia']?.[0]?.source_url;
          return (
            <a href={`/blog/${post.slug}`} class="card" style="text-decoration:none;">
              {thumb && (
                <div class="card-image" style={`background-image: url(${thumb})`}></div>
              )}
              <div class="card-content">
                <span class="date">{post.date?.slice(0, 10)}</span>
                <h3 set:html={post.title.rendered} />
                <p set:html={post.excerpt?.rendered?.replace(/<[^>]+>/g, '').slice(0, 80) + '...'} />
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <section class="section alt-bg">
   <div class="container">
    <div class="section-header">
     <h2>精選產品型錄</h2>
     <a href="/products" class="more-link">查看全部產品 →</a>
    </div>
    <div class="grid">
     {products.map((product: any) => (
      <div class="card">
       {product._embedded?.['wp:featuredmedia']?.[0]?.source_url && (
        <div class="card-image" style={`background-image: url(${product._embedded['wp:featuredmedia'][0].source_url})`}></div>
       )}
       <div class="card-content">
        <h3>{product.title?.rendered}</h3>
        {product.acf?.short_summary && <p>{product.acf.short_summary}</p>}
        <a href={`/products/${product.slug}`} class="cta">{product.acf?.cta_label || '立即洽詢'}</a>
       </div>
      </div>
     ))}
    </div>
   </div>
  </section>
 </main>
</Layout>

<style>
 :root {
  --bg: #0f0f0f;
  --surface: #1a1a1a;
  --primary: #d4af37;
  --text: #e0e0e0;
  --text-muted: #a0a0a0;
 }
 body {
  background: var(--bg);
  color: var(--text);
  font-family: "PingFang TC", "Microsoft JhengHei", sans-serif;
  margin: 0;
 }
 .container {
  max-width: 1000px;
  margin: 0 auto;
  padding: 0 20px;
 }
 .hero {
  background: linear-gradient(rgba(0,0,0,0.7), rgba(0,0,0,0.7)), url('https://images.unsplash.com/photo-1550009158-9ebf69173e03?auto=format&fit=crop&q=80&w=1200');
  background-size: cover;
  background-position: center;
  padding: 80px 0;
  text-align: center;
  border-bottom: 2px solid var(--primary);
 }
 h1 { font-size: 3rem; margin: 0; color: var(--primary); letter-spacing: 4px; }
 .tagline { font-size: 1.2rem; opacity: 0.8; margin: 10px 0 30px; }
 .section { padding: 60px 0; }
 .alt-bg { background: #0a0a0a; }
 .section-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 40px; }
 h2 { border-left: 4px solid var(--primary); padding-left: 15px; margin: 0; }
 .grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 30px; }
 .card { background: var(--surface); border-radius: 8px; overflow: hidden; transition: transform 0.3s; border: 1px solid #333; }
 .card:hover { transform: translateY(-5px); }
 .card-image { height: 200px; background-size: cover; background-position: center; }
 .card-content { padding: 25px; }
 .date { font-size: 0.8rem; color: var(--primary); font-weight: bold; }
 h3 { margin: 10px 0; font-size: 1.4rem; }
 p { color: var(--text-muted); font-size: 0.95rem; line-height: 1.6; }
 .status-tag { display: inline-block; padding: 4px 12px; background: #28a745; color: white; border-radius: 4px; font-size: 0.8rem; margin-top: 15px; }
 .cta { display: inline-block; margin-top: 15px; color: var(--primary); font-weight: bold; text-decoration: underline; }
 .more-link { color: var(--primary); text-decoration: none; font-size: 0.9rem; }
</style>