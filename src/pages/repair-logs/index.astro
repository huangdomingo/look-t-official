---
import Layout from '../../layouts/Layout.astro';
import { fetchRepairLogs } from '../../lib/wordpress';

const repairLogs = await fetchRepairLogs(100);
---

<Layout title="維修日誌 | Look-T 真空管工作室">
  <main>
    <header class="page-hero">
      <div class="container">
        <h1>職人維修實錄</h1>
        <p>真實案例｜保養知識｜技術分享</p>
      </div>
    </header>

    <section class="section">
      <div class="container">
        <div class="grid">
          {repairLogs.map((log: any) => (
            <a href={`/repair-logs/${log.slug}`} class="card">
              {log._embedded?.['wp:featuredmedia']?.[0]?.source_url && (
                <div class="card-image" style={`background-image: url(${log._embedded['wp:featuredmedia'][0].source_url})`}></div>
              )}
              <div class="card-content">
                <span class="date">{log.date?.slice(0, 10)}</span>
                <h2>{log.title?.rendered}</h2>
                {log.acf?.excerpt && <p>{log.acf.excerpt}</p>}
                {log.acf?.brand && <span class="tag">{log.acf.brand}</span>}
                {log.acf?.category && <span class="tag">{log.acf.category}</span>}
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  :root { --bg: #0f0f0f; --surface: #1a1a1a; --primary: #d4af37; --text: #e0e0e0; --text-muted: #a0a0a0; }
  body { background: var(--bg); color: var(--text); font-family: "PingFang TC", "Microsoft JhengHei", sans-serif; margin: 0; }
  .container { max-width: 1000px; margin: 0 auto; padding: 0 20px; }
  .page-hero { padding: 60px 0; text-align: center; border-bottom: 2px solid var(--primary); }
  h1 { font-size: 2.5rem; margin: 0; color: var(--primary); }
  .page-hero p { color: var(--text-muted); margin: 10px 0 0; }
  .section { padding: 60px 0; }
  .grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 30px; }
  .card { background: var(--surface); border-radius: 8px; overflow: hidden; border: 1px solid #333; text-decoration: none; color: var(--text); transition: transform 0.3s; display: block; }
  .card:hover { transform: translateY(-5px); }
  .card-image { height: 200px; background-size: cover; background-position: center; }
  .card-content { padding: 25px; }
  .date { font-size: 0.8rem; color: var(--primary); font-weight: bold; }
  h2 { margin: 8px 0 10px; font-size: 1.3rem; color: var(--text); }
  p { color: var(--text-muted); font-size: 0.95rem; line-height: 1.6; margin: 0 0 12px; }
  .tag { display: inline-block; padding: 3px 10px; background: #2a2a2a; border: 1px solid #444; border-radius: 4px; font-size: 0.8rem; color: var(--text-muted); margin-right: 6px; }
</style>